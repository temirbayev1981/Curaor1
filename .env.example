# =============================================================================
# The Emerald Pour — Environment Variables
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- App (public) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Vercel): https://curaor1.vercel.app
NEXT_PUBLIC_APP_NAME=The Emerald Pour
NEXT_PUBLIC_SUPPORT_EMAIL=bookings@emeraldpour.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_PLACE_ID=
NEXT_PUBLIC_BUSINESS_PHONE=+1-704-555-0199
NEXT_PUBLIC_DEFAULT_TENANT_ID=a0000000-0000-4000-8000-000000000001

# --- Cron (Vercel Cron / external scheduler) ---
CRON_SECRET=generate-a-random-secret

# --- Supabase (required) ---
# Get real values from Supabase Dashboard → Settings → API (not placeholders!)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe (payments — optional for local UI) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- OpenAI (admin AI SEO — optional) ---
OPENAI_API_KEY=sk-...

# --- Mapbox (delivery distance — optional) ---
MAPBOX_ACCESS_TOKEN=pk....
# Origin coordinates for distance calc (default: Charlotte, NC)
MAPBOX_ORIGIN_LAT=35.2271
MAPBOX_ORIGIN_LNG=-80.8431

# --- Server-only tenant override (optional, same as NEXT_PUBLIC_DEFAULT_TENANT_ID) ---
# DEFAULT_TENANT_ID=a0000000-0000-4000-8000-000000000001

# =============================================================================
# Edge Function secrets — set in Supabase Dashboard → Edge Functions → Secrets
# (not in .env.local for production; listed here for reference)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=bookings@emeraldpour.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# --- Observability (optional) ---
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
